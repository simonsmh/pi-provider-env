{
  "name": "pi-provider-env",
  "version": "1.0.5",
  "description": "Pi extension: registers OpenAI-completions and/or Anthropic-messages providers from environment variables (OPENAI_ENV_*, ANTHROPIC_ENV_*)",
  "author": "Simon Shi <simonsmh@gmail.com>",
  "keywords": [
    "pi-package"
  ],
  "main": "./extensions/env-provider.ts",
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simonsmh/pi-provider-env.git"
  },
  "license": "MIT",
  "scripts": {
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit",
    "build": "node -e \"process.exit(0)\""
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.10",
    "@earendil-works/pi-coding-agent": "^0.79.10",
    "typescript": "^5.8.3"
  }
}
